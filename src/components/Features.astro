---
const features = [
  {
    icon: '<svg class="w-6 h-6 text-hiroku-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>',
    bg: 'bg-hiroku-primary/15',
    title: 'Video Backgrounds',
    desc: 'Immersive animated video playing behind every screen. Not a static image — a living background.',
  },
  {
    icon: '<svg class="w-6 h-6 text-hiroku-green" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>',
    bg: 'bg-hiroku-green/15',
    title: 'Microsoft Auth',
    desc: 'Full Microsoft account support with secure OAuth. Plus offline & Yggdrasil servers.',
  },
  {
    icon: '<svg class="w-6 h-6 text-hiroku-amber" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>',
    bg: 'bg-hiroku-amber/15',
    title: 'Mod Loaders',
    desc: 'Forge, Fabric, NeoForge, Quilt, OptiFine, Cleanroom — all supported with one-tap install.',
  },
  {
    icon: '<svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>',
    bg: 'bg-purple-500/15',
    title: 'Glassmorphism UI',
    desc: 'Frosted glass cards, subtle borders, animated transitions — a UI that feels premium.',
  },
  {
    icon: '<svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
    bg: 'bg-blue-500/15',
    title: 'Touch Controls',
    desc: 'Built-in virtual joystick, gamepad support, custom control layouts with layer editor.',
  },
  {
    icon: '<svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
    bg: 'bg-cyan-500/15',
    title: 'Multiple Renderers',
    desc: 'GL4ES, VirGL, Vulkan Zink, Freedreno — pick the best renderer for your GPU. Custom drivers too.',
  },
];
---

<section id="features" class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-hiroku-dark via-hiroku-dark/95 to-hiroku-dark"></div>
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <span class="text-hiroku-primary text-sm font-semibold tracking-widest uppercase">Features</span>
      <h2 class="text-4xl md:text-5xl font-bold mt-3 mb-4">Built for the Future</h2>
      <p class="text-hiroku-accent/60 text-lg max-w-2xl mx-auto">Every pixel crafted with care. Every interaction designed to feel alive.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((f, i) => (
        <div class="feature-card scroll-reveal glass rounded-2xl p-6" style={`transition-delay:${i * 0.08}s`}>
          <div class={`w-12 h-12 rounded-xl ${f.bg} flex items-center justify-center mb-4`}>
            <Fragment set:html={f.icon} />
          </div>
          <h3 class="text-lg font-bold mb-2">{f.title}</h3>
          <p class="text-hiroku-accent/50 text-sm leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
